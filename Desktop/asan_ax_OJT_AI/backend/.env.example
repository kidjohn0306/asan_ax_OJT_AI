# Claude API (Anthropic) - 실제 키 발급 후 입력
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Google Drive Service Account JSON 경로
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# Google Drive 폴더 ID
GDRIVE_QUESTION_BANK_FOLDER_ID=your_folder_id_here
GDRIVE_RESULT_LOG_FOLDER_ID=your_folder_id_here

# JWT 설정
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# 개발 모드 (true면 mock 데이터 사용, Claude API/Drive 호출 안함)
USE_MOCK_DATA=true
